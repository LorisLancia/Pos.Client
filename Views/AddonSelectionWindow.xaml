<!-- Views/AddonSelectionWindow.xaml -->
<Window x:Class="POS.Client.Views.AddonSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Addons" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#FFF0F0F0">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding AddonGroupName}" FontSize="18" FontWeight="Bold" 
                   Foreground="#FF333333" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" 
                   Text="{Binding MaxQuantityText}" 
                   FontSize="12" Foreground="#FF666666" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icAddonItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="6" Margin="0,0,0,8" 
                                BorderBrush="#FFDDDDDD" BorderThickness="1" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ItemName}" FontWeight="Bold" 
                                               FontSize="14" Foreground="#FF333333"/>
                                    <TextBlock Text="{Binding PriceText}" FontSize="12" 
                                               Foreground="#FF007ACC"/>
                                </StackPanel>

                                <Button Grid.Column="1" Content="-" Width="32" Height="32" 
                                        Margin="0,0,5,0" Click="BtnDecrease_Click" 
                                        Tag="{Binding}" Background="#FFEF4444" 
                                        Foreground="White" BorderThickness="0"/>
                                
                                <TextBlock Grid.Column="2" Text="{Binding Quantity}" 
                                           Width="40" TextAlignment="Center" 
                                           VerticalAlignment="Center" FontSize="16" 
                                           FontWeight="Bold"/>
                                
                                <Button Grid.Column="3" Content="+" Width="32" Height="32" 
                                        Margin="5,0,0,0" Click="BtnIncrease_Click" 
                                        Tag="{Binding}" Background="#FF10B981" 
                                        Foreground="White" BorderThickness="0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="{Binding TotalSelectedText}" Margin="0,0,15,0" 
                       VerticalAlignment="Center" FontSize="14" Foreground="#FF666666"/>
            <Button Content="Cancel" Width="100" Height="40" Margin="0,0,10,0" 
                    Click="BtnCancel_Click" Background="#FF6B7280" Foreground="White"/>
            <Button Content="Add to Cart" Width="120" Height="40" Click="BtnAdd_Click" 
                    Background="#FF10B981" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>