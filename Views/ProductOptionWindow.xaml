<Window x:Class="POS.Client.Views.ProductOptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Options" Height="500" Width="500"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="spOptions" Margin="20">
            <TextBlock x:Name="txtProductName" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="Select your options:" FontSize="14" Margin="0,0,0,10"/>

            <!-- Options will be added dynamically -->

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <TextBlock x:Name="txtTotal" FontSize="16" FontWeight="Bold" Margin="0,0,20,0"/>
                <Button Content="Cancel" Width="80" Margin="5,0" Click="btnCancel_Click"/>
                <Button Content="OK" Width="80" Margin="5,0" Click="btnOK_Click" Background="#FF007ACC" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>