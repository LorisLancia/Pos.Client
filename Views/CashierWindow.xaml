<Window x:Class="POS.Client.Views.CashierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cashier" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F0F0">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Products -->
        <Border Grid.Column="0" Background="White" Margin="10" CornerRadius="8" BorderBrush="#FFDDDDDD" BorderThickness="1">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Products" FontSize="22" FontWeight="Bold" Foreground="#FF333333" Margin="0,0,0,10"/>

                <!-- Info bar -->
                <Border Grid.Row="1" Background="#FFE8F4FD" CornerRadius="4" Padding="10,5" Margin="0,0,0,10">
                    <TextBlock x:Name="txtProductInfo" Text="Click a product to add to cart. Products with ⚙ have options, ➕ have addons."
                               Foreground="#FF007ACC" FontSize="12"/>
                </Border>

                <!-- Variants selector -->
                <ComboBox x:Name="cbVariants" Grid.Row="2" Margin="0,0,0,10"
                          SelectionChanged="cbVariants_SelectionChanged"
                          DisplayMemberPath="Name" Visibility="Collapsed"/>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icProducts">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="160" Height="110" Margin="8" Click="ProductButton_Click"
                                        Tag="{Binding ServerId}" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#FF3C82F6"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="10"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}"
                                                                BorderBrush="{TemplateBinding BorderBrush}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF2563EB"/>
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#FF1D4ED8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding BasePrice, StringFormat='{}{0:F2} THB'}"
                                                   FontSize="12" Opacity="0.9" TextAlignment="Center"/>
                                        <TextBlock Text="⚙ Options" FontSize="10" Opacity="0.7"
                                                   TextAlignment="Center" Margin="0,4,0,0"
                                                   Visibility="{Binding HasModifiers, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="➕ Addons" FontSize="10" Opacity="0.7"
                                                   TextAlignment="Center" Margin="0,2,0,0"
                                                   Visibility="{Binding HasAddons, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- RIGHT: Cart -->
        <Border Grid.Column="1" Background="White" Margin="10" CornerRadius="8" BorderBrush="#FFDDDDDD" BorderThickness="1">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Cart" FontSize="22" FontWeight="Bold" Foreground="#FF333333" Margin="0,0,0,10"/>

                <ListBox x:Name="lbCart" Grid.Row="1" Margin="0,0,0,10"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                <!-- Separator -->
                <Border Grid.Row="2" Height="1" Background="#FFEEEEEE" Margin="0,0,0,10"/>

                <TextBlock x:Name="txtSubtotal" Grid.Row="3" Text="Subtotal: 0.00 THB"
                           FontSize="16" Foreground="#FF666666" Margin="0,0,0,5"/>
                <TextBlock x:Name="txtTax" Grid.Row="4" Text="Tax: 0.00 THB"
                           FontSize="14" Foreground="#FF999999" Margin="0,0,0,5"/>

                <Border Grid.Row="5" Background="#FFF0F9FF" CornerRadius="6" Padding="15" Margin="0,10">
                    <TextBlock x:Name="txtTotal" Text="Total: 0.00 THB" FontSize="28"
                               FontWeight="Bold" Foreground="#FF007ACC" HorizontalAlignment="Right"/>
                </Border>

                <Button x:Name="btnPay" Grid.Row="6" Content="PAY CASH" Height="60"
                        Background="#FF10B981" Foreground="White" FontSize="20"
                        FontWeight="Bold" Click="btnPay_Click" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF059669"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FF047857"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>